<!DOCTYPE html>
<html lang="en">
<head>
   <%- include('./partials/head') %>
   <title>Blog</title>
</head>
<body>
    <%- include('./partials/nav') %>
    <div class="container">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverImageURL %>" width="700px" alt="">
        <p><%= blog.body %></p>
    </div>
   
    <div class="container mt-3">
        <h1>Comments(<%= comments.length %>) </h1>
        <% if (locals.user) { %> 
         <form action="/blog/<%=blog._id%>" method="post">
            <div class="mb-3">
                <input type="content" placeholder="Enter your Comment" name="content" class="form-control" id="content" aria-describedby="emailHelp">
            </div>
            
            <button type="submit" class="btn btn-primary">Add</button>
        </form>
        <% } %>
        
    </div>

     <div class="container mt-3">
        <% comments.forEach(comment => { %>
         <div>
            <img src="<%=comment.createdBy.profileImageURL%>" width="50px" alt="">
            <%= comment.createdBy.fullName %>: <pre><%= comment.content %></pre>
         </div>
        <% }) %>
    </div>
    <%- include('./partials/scripts') %>
</body>
</html>